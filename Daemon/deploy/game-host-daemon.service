[Unit]
Description=Game Host Daemon
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/game-host-daemon/current
EnvironmentFile=/etc/game-host-daemon.env
ExecStart=/opt/game-host-daemon/current/game-host-daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
